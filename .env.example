# --- SQL Server (ERP, només lectura) ---
SQL_SERVER=servidor\instancia
SQL_DATABASE=nom_base_dades
SQL_USER=usuari_sql
SQL_PASSWORD=contrasenya_segura

# Ruta absoluta a l'app germana (motor de càlcul d'embalatges).
# La nova app importa motor.py / consultes.py / regles.py / models.py des d'aquí.
PREPARACIO_PATH=P:\preparacioComandesVenda

# --- PostgreSQL (persistència de les agrupacions desades) ---
PG_HOST=labfc.agri-energia.local
PG_PORT=5432
PG_DATABASE=agrupaciocarregues
PG_USER=app_agrupacions
PG_PASSWORD=...
# Mida del pool (per defecte 1-5)
PG_POOL_MIN=1
PG_POOL_MAX=5

# --- Power BI (endpoint /api/pbi/carregues) ---
# Clau secreta que Power BI haurà d'enviar al header X-Api-Key.
# Genera-la amb: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Si està buida, l'endpoint retorna 503 (no exposa dades).
PBI_API_KEY=
